&split
mults     = 1,3                                   !low-spin, high-spin multiplicity
icp       = 2                                     !number of independent-coupling parameter
socmat    = (-68.9751,-63.8306),(0,21.3239)       !spin-orbit matrix elements
delta     = 186.4,40.5                            !delta is minimum energy gap at r-/+, and r0 [cm-1]
